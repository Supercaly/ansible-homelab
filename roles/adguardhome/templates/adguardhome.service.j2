[Unit]
Description=AdGuard Home: Network-level blocker
ConditionFileIsExecutable={{ adguardhome_bin_file }}
After=syslog.target
After=network-online.target

[Service]
Type=simple
User={{ adguardhome_user }}
Group={{ adguardhome_group }}
StartLimitInterval=5
StartLimitBurst=10
WorkingDirectory={{ adguardhome_data_dir }}
ExecStart="{{ adguardhome_bin_file }}" "-s" "run" --work-dir "{{ adguardhome_data_dir }}" --config "{{ adguardhome_conf_file }}"
Restart=always
RestartSec=10
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
